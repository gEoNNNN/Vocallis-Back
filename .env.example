# ── Core ──────────────────────────────────────────────────────────────────────
PORT=3000

# ── Speech-to-Text (Deepgram) ──────────────────────────────────────────────────
DEEPGRAM_API_KEY=

# ── LLM (OpenAI) ───────────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ── Text-to-Speech (ElevenLabs) ────────────────────────────────────────────────
ELEVENLABS_API_KEY=

# ── Telegram lead notifications ─────────────────────────────────────────────────
# Get token from @BotFather, chat ID by messaging @userinfobot after starting your bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Google Calendar (Service Account) ──────────────────────────────────────────
# Calendar ID: found in Google Calendar → Settings → your calendar → "Calendar ID"
GOOGLE_CALENDAR_ID=

# Service account JSON key (minified to one line, or base64-encoded)
# How to get: Google Cloud Console → IAM → Service Accounts → Create → Keys → JSON
# Then share your calendar with the service account email as "Make changes to events"
GOOGLE_SERVICE_ACCOUNT_KEY=

# Optional: max simultaneous bookings per 1-hour slot (default: 2)
BOOKING_CAPACITY=2
